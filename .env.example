# Environment variables — copy to .env.dev (local) or .env.prod (deployment).
#
# Dev uses OpenRouter (config/llm.toml: provider = "openrouter"):
#   OPENROUTER_API_KEY=sk-or-...
#
# Prod uses Anthropic (Ansible templates config with provider = "anthropic"):
#   ANTHROPIC_API_KEY=sk-ant-...

ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_PREMIUM_CHANNEL_ID=-100...
TELEGRAM_FREE_CHANNEL_ID=-100...
TELEGRAM_OPERATOR_CHAT_ID=...
COINGECKO_API_KEY=CG-...
