{
  "name": "evening_report",
  "description": "Evening recap. Closes the loop on the day — scores every setup honestly, wraps up what happened, sets up overnight watch. This is where daily accountability lives.",
  "input_schema": {
    "type": "object",
    "required": [
      "regime_status",
      "regime_duration_days",
      "regime_narrative",
      "scorecard",
      "setups",
      "overnight_narrative",
      "market_narrative",
      "significance"
    ],
    "properties": {
      "regime_status": {
        "type": "string",
        "enum": [
          "trending_up",
          "trending_down",
          "range_bound",
          "breakout",
          "breakdown",
          "volatile",
          "uncertain"
        ],
        "description": "Current market regime classification."
      },
      "regime_duration_days": {
        "type": "integer",
        "description": "How many days the current regime has persisted."
      },
      "regime_narrative": {
        "type": "string",
        "description": "End-of-day regime assessment. Has anything changed today?"
      },
      "scorecard": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "asset",
            "direction",
            "trigger_level",
            "outcome",
            "assessment",
            "narrative"
          ],
          "properties": {
            "asset": {
              "type": "string",
              "description": "Asset symbol."
            },
            "direction": {
              "type": "string",
              "enum": ["long", "short", "neutral"],
              "description": "Direction of the original setup."
            },
            "trigger_level": {
              "type": "number",
              "description": "Trigger level from the original setup."
            },
            "outcome": {
              "type": "string",
              "enum": ["triggered", "invalidated", "expired", "active"],
              "description": "What happened to this setup today."
            },
            "outcome_price": {
              "type": ["number", "null"],
              "description": "Price at resolution. Null if still active."
            },
            "assessment": {
              "type": "string",
              "enum": ["hit", "miss", "neutral", "pending"],
              "description": "Honest assessment. Hit means the thesis played out. Miss means it didn't."
            },
            "miss_reason": {
              "type": ["string", "null"],
              "enum": [
                "wrong_direction",
                "wrong_level",
                "wrong_timing",
                "external_shock",
                null
              ],
              "description": "For misses only: why did it miss? Null for hits and pending. Be honest — this feeds the failure taxonomy."
            },
            "narrative": {
              "type": "string",
              "description": "What happened with this setup. Direct, honest debrief."
            }
          }
        },
        "description": "Structured scoring of every setup from today. Score them all — don't skip the uncomfortable ones."
      },
      "setups": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "asset",
            "direction",
            "trigger_condition",
            "trigger_level",
            "narrative"
          ],
          "properties": {
            "asset": {
              "type": "string",
              "description": "Asset symbol."
            },
            "direction": {
              "type": "string",
              "enum": ["long", "short", "neutral"],
              "description": "Directional bias of the setup."
            },
            "trigger_condition": {
              "type": "string",
              "enum": [
                "price_above",
                "price_below",
                "indicator_above",
                "indicator_below"
              ],
              "description": "Condition type that activates this setup."
            },
            "trigger_level": {
              "type": "number",
              "description": "Price or indicator value that triggers the setup."
            },
            "trigger_field": {
              "type": ["string", "null"],
              "description": "For indicator triggers: indicator name. Null for price triggers."
            },
            "target_level": {
              "type": "number",
              "description": "Price target if the setup plays out."
            },
            "invalidation_level": {
              "type": "number",
              "description": "Price level that invalidates this setup."
            },
            "confidence": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0,
              "description": "Confidence in this setup (0.0-1.0)."
            },
            "timeframe": {
              "type": "string",
              "enum": ["intraday", "swing", "position"],
              "description": "Expected timeframe for this setup."
            },
            "narrative": {
              "type": "string",
              "description": "Why this overnight setup matters and what to watch."
            }
          }
        },
        "description": "Overnight watch setups. What to monitor through Asia and Europe sessions."
      },
      "overnight_narrative": {
        "type": "string",
        "description": "What to monitor overnight. Carries forward or updates active setups for the Asia/Europe sessions."
      },
      "market_narrative": {
        "type": "string",
        "description": "Full day editorial. How the day's calls played out, notable developments, honest debrief."
      },
      "significance": {
        "type": "object",
        "required": ["magnitude", "surprise", "regime_relevance"],
        "properties": {
          "magnitude": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "How significant in market terms."
          },
          "surprise": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "How unexpected given the current read."
          },
          "regime_relevance": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Does this potentially change the bigger picture."
          }
        },
        "description": "Analytical significance ratings."
      }
    }
  }
}
