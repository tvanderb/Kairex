{
  "name": "alert_report",
  "description": "Real-time alert. Something meaningfully changed — this is the shoulder tap. Three beats: what happened, what it means, what to watch next.",
  "input_schema": {
    "type": "object",
    "required": [
      "asset",
      "trigger_summary",
      "context_narrative",
      "watch_narrative",
      "setups",
      "significance"
    ],
    "properties": {
      "asset": {
        "type": "string",
        "description": "Primary asset this alert concerns."
      },
      "trigger_summary": {
        "type": "string",
        "description": "What happened. The event that triggered this alert."
      },
      "context_narrative": {
        "type": "string",
        "description": "What it means in context of the current read. Connect to recent reports and the broader market picture."
      },
      "watch_narrative": {
        "type": "string",
        "description": "What to watch next. Specific levels, scenarios, follow-through signals."
      },
      "setups": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "asset",
            "direction",
            "trigger_condition",
            "trigger_level",
            "narrative"
          ],
          "properties": {
            "asset": {
              "type": "string",
              "description": "Asset symbol."
            },
            "direction": {
              "type": "string",
              "enum": ["long", "short", "neutral"],
              "description": "Directional bias of the setup."
            },
            "trigger_condition": {
              "type": "string",
              "enum": [
                "price_above",
                "price_below",
                "indicator_above",
                "indicator_below"
              ],
              "description": "Condition type that activates this setup."
            },
            "trigger_level": {
              "type": "number",
              "description": "Price or indicator value that triggers the setup."
            },
            "trigger_field": {
              "type": ["string", "null"],
              "description": "For indicator triggers: indicator name. Null for price triggers."
            },
            "target_level": {
              "type": "number",
              "description": "Price target if the setup plays out."
            },
            "invalidation_level": {
              "type": "number",
              "description": "Price level that invalidates this setup."
            },
            "confidence": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0,
              "description": "Confidence in this setup (0.0-1.0)."
            },
            "timeframe": {
              "type": "string",
              "enum": ["intraday", "swing", "position"],
              "description": "Expected timeframe for this setup."
            },
            "narrative": {
              "type": "string",
              "description": "Why this setup emerged from this event."
            }
          }
        },
        "description": "Any new setups arising from this event. May be empty if the alert is informational."
      },
      "significance": {
        "type": "object",
        "required": ["magnitude", "surprise", "regime_relevance"],
        "properties": {
          "magnitude": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "How significant in market terms."
          },
          "surprise": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "How unexpected given the current read."
          },
          "regime_relevance": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Does this potentially change the bigger picture."
          }
        },
        "description": "Analytical significance ratings."
      }
    }
  }
}
